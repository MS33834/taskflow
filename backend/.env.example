# 应用配置
DEBUG=false
API_HOST=127.0.0.1
API_PORT=8000

# 认证配置（本地桌面应用使用）
# 若设置 API_TOKEN，则使用该固定 token；否则启动时自动生成并写入临时文件。
# API_TOKEN_FILE 可自定义 token 文件路径，未设置时默认写到系统临时目录。
# API_TOKEN=your-secure-token-here
# API_TOKEN_FILE=/path/to/taskflow_api_token.txt

# 大模型配置
LLM_PROVIDER=openai
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# 路径配置
GIT_WORKSPACE=./workspace
PLUGINS_DIR=./plugins

# CORS 配置：逗号分隔的允许来源
# 生产环境禁止设置为 "*" 同时携带凭证
CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# API 文档开关：生产环境默认关闭，需要时设置为 true
ENABLE_DOCS=false
